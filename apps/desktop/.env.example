LOUPE_SLACK_OAUTH_CLIENT_ID=
LOUPE_SLACK_OAUTH_CLIENT_SECRET=
LOUPE_GOOGLE_OAUTH_CLIENT_ID=
LOUPE_GOOGLE_OAUTH_CLIENT_SECRET=
# JSON array of pre-bundled GitLab Applications (PKCE public clients).
# Each entry: {"url": "https://gitlab.example.com", "clientId": "<application-id>"}
# Example:
# LOUPE_GITLAB_OAUTH_INSTANCES=[{"url":"https://gitlab.rayark.com","clientId":"abc123..."}]
LOUPE_GITLAB_OAUTH_INSTANCES=

# Optional short label rendered as a badge next to the version in the
# Home header. Use this in packaging CI variables to mark an internal /
# downstream build distinctly from upstream. Leave empty for upstream.
LOUPE_INTERNAL_BRAND=
