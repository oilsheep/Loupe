{
  "name": "desktop",
  "version": "0.5.0",
  "private": true,
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "pretest": "node ../../scripts/ensure-node-native.mjs better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "spike:airplay": "electron scripts/spike-airplay.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "happy-dom": "^15.7.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "build": {
    "appId": "com.loupe.qa-recorder",
    "productName": "Loupe QA Recorder",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "out/**/*",
      "build/icon.png",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "oilsheep",
        "repo": "Loupe"
      }
    ],
    "asarUnpack": [
      "node_modules/.pnpm/@ffmpeg-installer+*/node_modules/@ffmpeg-installer/**",
      "node_modules/@ffmpeg-installer/**"
    ],
    "extraResources": [
      {
        "from": "vendor/scrcpy",
        "to": "vendor/scrcpy",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/whisper",
        "to": "vendor/whisper",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/uxplay",
        "to": "vendor/uxplay",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/go-ios",
        "to": "vendor/go-ios",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/faster-whisper",
        "to": "vendor/faster-whisper",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Loupe QA Recorder"
    }
  }
}
